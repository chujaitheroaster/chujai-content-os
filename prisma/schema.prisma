generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  CONTENT_STRATEGIST
  DESIGNER
  PUBLISHER
}

enum Platform {
  INSTAGRAM
  TIKTOK
  FACEBOOK
}

enum ContentType {
  REELS
  STATIC_POST
  CAROUSEL
  STORY
  SHORT_VIDEO
  LONG_VIDEO
}

enum ContentStatus {
  DRAFT
  IN_PROGRESS
  IN_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  ANALYZED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  BLOCKED
}

enum ActivityAction {
  COMMENT
  STATUS_CHANGE
  ASSIGNMENT
  REVIEW_REQUESTED
  APPROVED
  CHANGES_REQUESTED
  FILE_UPLOADED
  METRICS_ENTERED
  TASK_CREATED
}

enum LarkActionType {
  APPROVE
  REQUEST_CHANGES
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String
  passwordHash String  @map("password_hash")
  role         Role    @default(PUBLISHER)
  avatarUrl    String? @map("avatar_url")
  larkUserId   String? @map("lark_user_id")
  isActive     Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contentItemsCreated ContentItem[]      @relation("ContentCreatedBy")
  tasksAssigned       Task[]             @relation("TaskAssignedTo")
  fileUploads         FileAttachment[]
  activityLogs        ActivityLog[]
  analyticsEntered    AnalyticsEntry[]
  settingsUpdated     AppSetting[]
  blockedDays         BlockedDay[]
  weeklyThemes        WeeklyTheme[]
  monthlyGoals        MonthlyGoal[]
  pipelineTemplates   PipelineTemplate[]
  larkTokens          LarkMessageToken[]

  @@map("users")
}

model ContentItem {
  id            String        @id @default(cuid())
  title         String
  platform      Platform
  contentType   ContentType   @map("content_type")
  targetDate    DateTime      @map("target_date") @db.Date
  weeklyTheme   String?       @map("weekly_theme")
  status        ContentStatus @default(DRAFT)
  brief         String?       @db.Text
  captionDraft  String?       @map("caption_draft") @db.Text
  hashtagsDraft String?       @map("hashtags_draft") @db.Text
  postGoal      String?       @map("post_goal")
  publishedAt   DateTime?     @map("published_at")

  createdById String @map("created_by")
  createdBy   User   @relation("ContentCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tasks        Task[]
  files        FileAttachment[]
  activityLogs ActivityLog[]
  analytics    AnalyticsEntry?
  larkTokens   LarkMessageToken[]

  @@index([targetDate])
  @@index([status])
  @@index([platform])
  @@map("content_items")
}

model PipelineTemplate {
  id          String       @id @default(cuid())
  platform    Platform?
  contentType ContentType? @map("content_type")
  name        String
  isDefault   Boolean      @default(false) @map("is_default")

  createdById String? @map("created_by")
  createdBy   User?   @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  stages PipelineTemplateStage[]

  @@map("pipeline_templates")
}

model PipelineTemplateStage {
  id                  String  @id @default(cuid())
  templateId          String  @map("template_id")
  name                String
  orderIndex          Int     @map("order_index")
  defaultAssigneeRole Role?   @map("default_assignee_role")
  dueDateOffsetDays   Int     @default(0) @map("due_date_offset_days")
  isReviewStage       Boolean @default(false) @map("is_review_stage")

  template PipelineTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("pipeline_template_stages")
}

model Task {
  id                  String     @id @default(cuid())
  contentItemId       String     @map("content_item_id")
  stageName           String     @map("stage_name")
  orderIndex          Int        @map("order_index")
  status              TaskStatus @default(PENDING)
  assignedToId        String?    @map("assigned_to")
  dueDate             DateTime?  @map("due_date") @db.Date
  completedAt         DateTime?  @map("completed_at")
  notes               String?    @db.Text
  isReviewStage       Boolean    @default(false) @map("is_review_stage")
  reviewRequestSentAt DateTime?  @map("review_request_sent_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contentItem  ContentItem       @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  assignedTo   User?             @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  files        FileAttachment[]
  activityLogs ActivityLog[]
  larkTokens   LarkMessageToken[]

  @@index([assignedToId])
  @@index([dueDate])
  @@index([contentItemId])
  @@map("tasks")
}

model FileAttachment {
  id            String  @id @default(cuid())
  contentItemId String? @map("content_item_id")
  taskId        String? @map("task_id")
  filename      String
  blobUrl       String  @map("blob_url")
  fileType      String  @map("file_type")
  fileSizeBytes Int?    @map("file_size_bytes")
  uploadedById  String  @map("uploaded_by")

  createdAt DateTime @default(now()) @map("created_at")

  contentItem ContentItem? @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  task        Task?        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy  User         @relation(fields: [uploadedById], references: [id])

  @@map("file_attachments")
}

model AnalyticsEntry {
  id            String @id @default(cuid())
  contentItemId String @unique @map("content_item_id")
  views         Int?
  reach         Int?
  likes         Int?
  comments      Int?
  shares        Int?
  saves         Int?
  enteredById   String @map("entered_by")

  enteredAt DateTime @default(now()) @map("entered_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  enteredBy   User        @relation(fields: [enteredById], references: [id])

  @@map("analytics_entries")
}

model ActivityLog {
  id            String         @id @default(cuid())
  contentItemId String         @map("content_item_id")
  taskId        String?        @map("task_id")
  actorId       String         @map("actor_id")
  action        ActivityAction
  payload       Json?

  createdAt DateTime @default(now()) @map("created_at")

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  task        Task?       @relation(fields: [taskId], references: [id], onDelete: SetNull)
  actor       User        @relation(fields: [actorId], references: [id])

  @@index([contentItemId])
  @@map("activity_logs")
}

model LarkMessageToken {
  id            String         @id @default(cuid())
  contentItemId String         @map("content_item_id")
  taskId        String?        @map("task_id")
  actionType    LarkActionType @map("action_type")
  token         String         @unique
  usedAt        DateTime?      @map("used_at")
  expiresAt     DateTime       @map("expires_at")
  createdById   String?        @map("created_by")

  createdAt DateTime @default(now()) @map("created_at")

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  task        Task?       @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdBy   User?       @relation(fields: [createdById], references: [id])

  @@map("lark_message_tokens")
}

model AppSetting {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String  @db.Text
  updatedById String? @map("updated_by")

  updatedAt DateTime @updatedAt @map("updated_at")

  updatedBy User? @relation(fields: [updatedById], references: [id])

  @@map("app_settings")
}

model BlockedDay {
  id          String   @id @default(cuid())
  date        DateTime @unique @db.Date
  reason      String?
  createdById String   @map("created_by")

  createdAt DateTime @default(now()) @map("created_at")

  createdBy User @relation(fields: [createdById], references: [id])

  @@map("blocked_days")
}

model WeeklyTheme {
  id          String @id @default(cuid())
  year        Int
  weekNumber  Int    @map("week_number")
  theme       String
  createdById String @map("created_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy User @relation(fields: [createdById], references: [id])

  @@unique([year, weekNumber])
  @@map("weekly_themes")
}

model MonthlyGoal {
  id          String    @id @default(cuid())
  year        Int
  month       Int
  platform    Platform?
  goalCount   Int       @map("goal_count")
  createdById String    @map("created_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy User @relation(fields: [createdById], references: [id])

  @@unique([year, month, platform])
  @@map("monthly_goals")
}
